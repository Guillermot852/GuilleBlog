---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import RatingBadge from '../../components/RatingBadge.astro'
import {
  client,
  coffeeShopsQuery,
  coffeeShopBySlugQuery,
  portableTextToHtml,
  formatDate,
  type CoffeeShop,
} from '../../lib/sanity'

export async function getStaticPaths() {
  const shops: CoffeeShop[] = await client.fetch(coffeeShopsQuery)
  return shops.map((shop) => ({ params: { slug: shop.slug.current } }))
}

const { slug } = Astro.params
const shop: CoffeeShop | null = await client.fetch(coffeeShopBySlugQuery, { slug })

if (!shop) {
  return Astro.redirect('/coffee')
}

const bodyHtml = shop.body ? portableTextToHtml(shop.body) : ''
---

<Layout
  title={`${shop.title} — Crema`}
  description={shop.summary}
  image={shop.mainImage}
>
  <Header slot="header" />

  <article class="coffee-post">

    <!-- Hero image -->
    {shop.mainImage && (
      <div class="post-hero">
        <img
          src={shop.mainImage}
          alt={shop.mainImageAlt || shop.title}
          class="post-hero-image"
        />
      </div>
    )}

    <div class="container post-container">

      <!-- Header card -->
      <div class="post-header">

        <div class="post-breadcrumb">
          <a href="/coffee">← Coffee reviews</a>
          {shop.neighborhood && <span>/ {shop.neighborhood}</span>}
        </div>

        <h1 class="post-title">{shop.title}</h1>

        {shop.summary && <p class="post-summary">{shop.summary}</p>}

        <!-- Meta row -->
        <div class="post-meta">
          {shop.rating && <RatingBadge rating={shop.rating} size="lg" />}

          <div class="meta-badges">
            {shop.neighborhood && (
              <span class="meta-badge meta-neighborhood">
                📍 {shop.neighborhood}
              </span>
            )}
            {shop.priceRange && (
              <span class="meta-badge meta-price">{shop.priceRange}</span>
            )}
          </div>
        </div>

        {shop.tags && shop.tags.length > 0 && (
          <ul class="post-tags">
            {shop.tags.map((tag: string) => <li class="tag">{tag}</li>)}
          </ul>
        )}

        {shop.publishedAt && (
          <time class="post-date" datetime={shop.publishedAt}>
            {formatDate(shop.publishedAt)}
          </time>
        )}
      </div>

      <!-- Body -->
      {bodyHtml ? (
        <div class="post-body prose" set:html={bodyHtml} />
      ) : (
        <div class="post-body prose">
          <p><em>Full review coming soon. In the meantime — it's worth a visit.</em></p>
        </div>
      )}

      <!-- Back link -->
      <div class="post-footer">
        <a href="/coffee" class="back-link">← Back to all reviews</a>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</Layout>

<style>
  /* Hero */
  .post-hero {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
  }

  .post-hero-image {
    width: 100%;
    height: 520px;
    object-fit: cover;
  }

  /* Container */
  .post-container {
    max-width: 760px;
  }

  /* Header card */
  .post-header {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    margin: -3rem auto 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 4px 24px rgba(44,24,16,0.1);
  }

  .post-breadcrumb {
    font-size: 0.8rem;
    color: var(--muted);
    display: flex;
    gap: 0.5rem;
  }

  .post-breadcrumb a { color: var(--caramel); }
  .post-breadcrumb a:hover { color: var(--espresso); }

  .post-title {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
  }

  .post-summary {
    font-size: 1.1rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.5;
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .meta-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .meta-badge {
    font-size: 0.8rem;
    padding: 4px 12px;
    border-radius: 20px;
    background: var(--milk);
    border: 1px solid var(--border);
    color: var(--espresso);
    font-weight: 500;
  }

  .meta-neighborhood { color: var(--caramel); }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }

  .tag {
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 20px;
    background: var(--milk);
    border: 1px solid var(--border);
    color: var(--muted);
    font-weight: 500;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--muted);
  }

  /* Body */
  .post-body {
    margin: 0 auto 3rem;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  /* Footer */
  .post-footer {
    padding: 2rem 0 1rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--caramel);
    font-weight: 500;
  }

  .back-link:hover { color: var(--espresso); }
</style>
