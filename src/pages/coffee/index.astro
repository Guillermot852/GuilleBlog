---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import CoffeeCard from '../../components/CoffeeCard.astro'
import { client, coffeeShopsQuery, type CoffeeShop } from '../../lib/sanity'

const coffeeShops: CoffeeShop[] = await client.fetch(coffeeShopsQuery)

// Group by neighborhood for the sidebar filter feel
const neighborhoods = [...new Set(coffeeShops.map((s: CoffeeShop) => s.neighborhood).filter(Boolean))]
---

<Layout
  title="Coffee Reviews — Crema"
  description="All coffee shop reviews in Madrid. From specialty coffee in Malasaña to hidden gems in Lavapiés."
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <div class="page-label">Madrid coffee</div>
      <h1 class="page-title">Coffee Reviews</h1>
      <p class="page-desc">
        Every place, honestly reviewed. Rated, mapped, and drunk too many times.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container layout">

      <!-- Sidebar filters -->
      {neighborhoods.length > 0 && (
        <aside class="sidebar">
          <h2 class="sidebar-title">Neighbourhoods</h2>
          <ul class="neighborhood-list">
            <li>
              <button class="nbh-btn active" data-nbh="all">All</button>
            </li>
            {neighborhoods.map((nbh: string) => (
              <li>
                <button class="nbh-btn" data-nbh={nbh}>{nbh}</button>
              </li>
            ))}
          </ul>
        </aside>
      )}

      <!-- Grid -->
      <div class="shops-wrap">
        {coffeeShops.length === 0 ? (
          <div class="empty-state">
            <span>☕</span>
            <p>No reviews yet — check back soon.</p>
          </div>
        ) : (
          <div class="grid" id="shops-grid">
            {coffeeShops.map((shop: CoffeeShop) => (
              <div class="grid-item" data-nbh={shop.neighborhood || ''}>
                <CoffeeCard shop={shop} />
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    background: var(--milk);
    border-bottom: 1px solid var(--border);
    padding: clamp(2.5rem, 6vw, 4rem) 0 clamp(1.5rem, 4vw, 2.5rem);
  }

  .page-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--caramel);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-family: var(--font-heading);
    color: var(--espresso);
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 500px;
  }

  .layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .sidebar-title {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    font-family: var(--font-body);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .neighborhood-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .nbh-btn {
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--muted);
    cursor: pointer;
    padding: 0.3rem 0;
    text-align: left;
    transition: color 0.15s;
    width: 100%;
  }

  .nbh-btn:hover,
  .nbh-btn.active { color: var(--espresso); font-weight: 600; }

  .shops-wrap { min-width: 0; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .grid-item.hidden { display: none; }

  .empty-state {
    padding: 4rem;
    text-align: center;
    color: var(--muted);
    font-size: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .empty-state span { font-size: 3rem; }

  @media (max-width: 700px) {
    .layout { grid-template-columns: 1fr; }
    .sidebar { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
    .sidebar-title { margin-bottom: 0; }
    .neighborhood-list { flex-direction: row; flex-wrap: wrap; gap: 0.5rem; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.nbh-btn')
  const items   = document.querySelectorAll<HTMLElement>('.grid-item')

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'))
      btn.classList.add('active')
      const nbh = btn.dataset.nbh || 'all'
      items.forEach((item) => {
        if (nbh === 'all' || item.dataset.nbh === nbh) {
          item.classList.remove('hidden')
        } else {
          item.classList.add('hidden')
        }
      })
    })
  })
</script>
