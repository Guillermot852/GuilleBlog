---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { client, stylePostsQuery, type StylePost, formatDate } from '../../lib/sanity'

const stylePosts: StylePost[] = await client.fetch(stylePostsQuery)
---

<Layout
  title="Style — Crema"
  description="Madrid lifestyle, fashion, and culture — curated through a coffee-shop lens."
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <div class="page-label">Lifestyle</div>
      <h1 class="page-title">Style</h1>
      <p class="page-desc">
        Madrid's culture, fashion, and spirit — filtered through the same honest lens as our coffee reviews.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {stylePosts.length === 0 ? (
        <div class="empty-state">
          <span>✨</span>
          <p>Style posts coming soon.</p>
        </div>
      ) : (
        <div class="posts-grid">
          {stylePosts.map((post: StylePost) => (
            <article class="style-card">
              <a href={`/style/${post.slug.current}`} class="style-card-link">
                <div class="style-image-wrap">
                  {post.mainImage ? (
                    <img src={post.mainImage} alt={post.mainImageAlt || post.title} loading="lazy" />
                  ) : (
                    <div class="style-placeholder">✨</div>
                  )}
                </div>
                <div class="style-body">
                  <h2 class="style-title">{post.title}</h2>
                  {post.summary && <p class="style-summary">{post.summary}</p>}
                  {post.publishedAt && (
                    <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    background: var(--milk);
    border-bottom: 1px solid var(--border);
    padding: clamp(2.5rem, 6vw, 4rem) 0 clamp(1.5rem, 4vw, 2.5rem);
  }

  .page-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--caramel);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-family: var(--font-heading);
    color: var(--espresso);
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 500px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .style-card {
    background: var(--white);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .style-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(44,24,16,0.1);
  }

  .style-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .style-image-wrap {
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--milk);
  }

  .style-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .style-card:hover img { transform: scale(1.04); }

  .style-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
  }

  .style-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .style-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--espresso);
    line-height: 1.25;
  }

  .style-summary {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .style-body time {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .empty-state {
    padding: 4rem;
    text-align: center;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .empty-state span { font-size: 3rem; }
</style>
