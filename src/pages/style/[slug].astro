---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import {
  client,
  stylePostsQuery,
  stylePostBySlugQuery,
  portableTextToHtml,
  formatDate,
  type StylePost,
} from '../../lib/sanity'

export async function getStaticPaths() {
  const posts: StylePost[] = await client.fetch(stylePostsQuery)
  return posts.map((post) => ({ params: { slug: post.slug.current } }))
}

const { slug } = Astro.params
const post: StylePost | null = await client.fetch(stylePostBySlugQuery, { slug })

if (!post) {
  return Astro.redirect('/style')
}

const bodyHtml = post.body ? portableTextToHtml(post.body) : ''
---

<Layout
  title={`${post.title} — Crema`}
  description={post.summary}
  image={post.mainImage}
>
  <Header slot="header" />

  <article class="style-post">

    {post.mainImage && (
      <div class="post-hero">
        <img src={post.mainImage} alt={post.mainImageAlt || post.title} class="post-hero-image" />
      </div>
    )}

    <div class="container post-container">
      <div class="post-header">
        <div class="post-breadcrumb">
          <a href="/style">← Style</a>
        </div>

        <h1 class="post-title">{post.title}</h1>

        {post.summary && <p class="post-summary">{post.summary}</p>}

        {post.publishedAt && (
          <time class="post-date" datetime={post.publishedAt}>
            {formatDate(post.publishedAt)}
          </time>
        )}
      </div>

      {bodyHtml ? (
        <div class="post-body prose" set:html={bodyHtml} />
      ) : (
        <div class="post-body prose">
          <p><em>Full post coming soon.</em></p>
        </div>
      )}

      <div class="post-footer">
        <a href="/style" class="back-link">← Back to style</a>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</Layout>

<style>
  .post-hero {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
  }

  .post-hero-image {
    width: 100%;
    height: 520px;
    object-fit: cover;
  }

  .post-container {
    max-width: 760px;
  }

  .post-header {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    margin: -3rem auto 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 4px 24px rgba(44,24,16,0.1);
  }

  .post-breadcrumb {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .post-breadcrumb a { color: var(--caramel); }
  .post-breadcrumb a:hover { color: var(--espresso); }

  .post-title {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
  }

  .post-summary {
    font-size: 1.1rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.5;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .post-body {
    margin: 0 auto 3rem;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .post-footer {
    padding: 2rem 0 1rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--caramel);
    font-weight: 500;
  }

  .back-link:hover { color: var(--espresso); }
</style>
