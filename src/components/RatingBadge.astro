---
export interface Props {
  rating: number
  size?: 'sm' | 'md' | 'lg'
}

const { rating, size = 'md' } = Astro.props

// Colour shifts from amber → caramel → espresso based on rating
function ratingColor(r: number): string {
  if (r >= 9) return '#1A5C2A'   // excellent — dark green
  if (r >= 7) return '#C8860A'   // good — caramel
  if (r >= 5) return '#9A6B00'   // average
  return '#8B2020'               // below average
}
---

<span class:list={['rating-badge', `rating-badge--${size}`]} style={`--badge-color: ${ratingColor(rating)}`}>
  <strong>{rating}</strong><span class="denom">/10</span>
</span>

<style>
  .rating-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
    background: color-mix(in srgb, var(--badge-color) 12%, white);
    color: var(--badge-color);
    border: 1.5px solid color-mix(in srgb, var(--badge-color) 30%, transparent);
    border-radius: 6px;
    font-family: var(--font-body);
    white-space: nowrap;
    line-height: 1;
  }

  .rating-badge--sm  { font-size: 0.75rem; padding: 2px 7px; }
  .rating-badge--md  { font-size: 0.9rem;  padding: 3px 9px; }
  .rating-badge--lg  { font-size: 1.5rem;  padding: 6px 16px; border-radius: 8px; }

  strong { font-weight: 700; }

  .denom {
    font-size: 0.7em;
    opacity: 0.7;
    font-weight: 400;
  }
</style>
